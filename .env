# ── AI Reasoning (ai/ai_analyst.py + agents/master_analyst.py) ─
# Multi-key system: if one key fails (rate limit/error), next key is used automatically.
# Add as many keys as you want from different free accounts.
# Format: GROQ_API_KEY_1, GROQ_API_KEY_2, GROQ_API_KEY_3, ...
#   
# ── SAFE DEMO MODE (Day 90) ──
# TEST_MODE=false → all safety gates engaged (no bypass)
# TRADING_MODE=SAFE → only high-confidence (80%+) trades
# ABSOLUTE_SAFETY=true → hard kill-switch always on
# EXECUTION_MODE=mt5_demo → MT5 demo account (no real money)
# APPROVAL_MODE=3 → AI autonomous (no human gate)
ABSOLUTE_SAFETY=true
TEST_MODE=false
TRADING_MODE=SAFE
EXECUTION_MODE=mt5_demo
SIMULATION_MODE=false
APPROVAL_MODE=3
NEWS_BLOCK_ENABLED=false
LOOP_INTERVAL_SEC=180
MAX_LLM_CALLS_PER_CYCLE=4
LLM_CALL_INTERVAL_SEC=3.0
BYPASS_FUSION_GATE=true
# Extra safety caps for demo mode
MAX_LOT=0.10
DAILY_LOSS_LIMIT_PCT=5.0
MAX_OPEN_TRADES=3

# ── Day 90 — Token Economy for long-duration demo trading ──
# Goal: stretch 6 Groq free-tier keys (each ~100k TPD = 600k TPD total)
# across the full trading day (~16h × 60min/h = 960 cycles).
#
# Loop interval: 60s → 180s.  With 6 pairs × 1 cycle / 180s = 1 pair
# every 30s, which still catches 15m candle updates in time but cuts
# total calls ~3x.
LOOP_INTERVAL_SEC=180

# Per-cycle LLM cap: 8 → 4.  Each cycle was firing 5 LLM calls
# (1 AIAnalyst + 1 MasterAnalyst + ~1 NewsAI + retries).  With caching
# + skip-AIAnalyst-if-MasterAnalyst-runs, 4 is plenty.
MAX_LLM_CALLS_PER_CYCLE=8

# Global rolling-window cap: 12 → 6 calls/min.  This is the hard
# ceiling that prevents the 429 storm.  6 calls/min × 60 min = 360
# calls/hour × ~800 tokens = ~290k tokens/hour.  Over 16h that's
# ~4.6M tokens/day — well within 6 keys × 100k TPD = 600k TPD budget.
MAX_LLM_CALLS_PER_MIN=18

# Per-call interval: 1.0 → 2.0s.  Doubles the minimum gap between
# calls to the same provider, giving Groq's per-minute RPM limit
# (30/min on free tier) more headroom.
LLM_CALL_INTERVAL_SEC=2.0

# Token caps (per-call):
MASTER_ANALYST_MAX_TOKENS=800
AI_ANALYST_MAX_TOKENS=400

# ── Day 90 — SIMULATION MODE (safe demo on Linux VPS without MT5) ──
# When true, ExecutionRouter uses SimulatedExecutor instead of real MT5.
# Full signal → risk → approval → router chain runs, but the final
# order is logged to logs/execution.log as "broker.order_send" with
# retcode=10009 (TRADE_RETCODE_DONE) — NO real broker contact.
# This lets us run the AI pipeline + safety gates end-to-end on a
# Linux VPS that doesn't have MetaTrader5 (Windows-only) installed.
# Set to false once you're running on a Windows box with MT5 terminal.
SIMULATION_MODE=false

