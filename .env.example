# ═══════════════════════════════════════════════════════════════
# Forex AI Trading System — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then edit .env with your actual credentials.
# NEVER commit .env to version control.

# ── CRITICAL SAFETY SETTINGS ───────────────────────────────────
# TEST_MODE: Set to "true" ONLY during initial development.
#            When true, bypasses news filter, confluence, RL veto,
#            master decision, and dead-zone protection.
#            Set to "false" for production trading.
TEST_MODE=false

# ── RISK MANAGEMENT ────────────────────────────────────────────
# Risk per trade (% of account equity)
# 0.5 = 0.5% per trade (recommended for production)
RISK_PER_TRADE=0.005

# Daily loss limit (% of account equity)
# When this is hit, trading halts for the rest of the day
# 5.0 = 5% daily loss limit (recommended for production)
DAILY_LOSS_LIMIT_PCT=5.0

# Max simultaneous open trades
MAX_OPEN_TRADES=6

# Max total positions (portfolio-wide headroom)
MAX_POSITIONS=8

# ── TELEGRAM BOT (for alerts and commands) ─────────────────────
# Get token from @BotFather on Telegram
# Day 102+ hotfix: renamed from TELEGRAM_BOT_TOKEN to TELEGRAM_TOKEN
# to match what the code actually reads (alerts/telegram_bot.py:234
# and config.py:259 both call os.getenv("TELEGRAM_TOKEN")). The old
# name silently disabled the bot for users who followed this example.
TELEGRAM_TOKEN=your_bot_token_here

# CRITICAL: Set allowed user IDs to prevent unauthorized access
# Without this, ANYONE can send /pause, /resume, /close to your bot
# Find your user ID: message @userinfobot on Telegram
# Format: comma-separated list of user IDs
ALLOWED_USER_IDS=123456789

# Optional: allow specific chat IDs (group chats)
# ALLOWED_CHAT_IDS=123456789,987654321

# ── MT5 CONNECTION ─────────────────────────────────────────────
# Path to MT5 terminal (Windows only)
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ── MT5 BROKER TIMEZONE OFFSET (P1 audit fix) ─────────────────
# Many MT5 brokers (IC Markets, Pepperstone, Exness, FXTM, etc.)
# configure their MT5 server to return bar OPEN time in BROKER
# SERVER TIME rather than true UTC. The broker server time is
# commonly GMT+2 in winter and GMT+3 in summer (the so-called
# "FX broker time" used to keep daily candles aligned with NY close).
#
# When that happens, the fetcher receives wall-clock seconds that
# are 2-3 hours AHEAD of true UTC, and `pd.to_datetime(unit='s')`
# silently treats them as UTC — producing timestamps that look
# "in the future" relative to UTC `now`. This is the exact root
# cause of the "11126s left on M15 candle" bug: trade entries
# block forever because the bar appears to still be forming.
#
# Set this to your broker's GMT offset (in hours). Examples:
#   MT5_BROKER_TZ_OFFSET_HOURS=0   ← broker server IS UTC (default)
#   MT5_BROKER_TZ_OFFSET_HOURS=2   ← broker is GMT+2 (winter)
#   MT5_BROKER_TZ_OFFSET_HOURS=3   ← broker is GMT+3 (summer / DST)
#
# How to verify: run the bot and watch the log for
#   "[MT5] Bar timestamps (UTC): first=... last=..."
# If `last` is in the FUTURE relative to UTC now, increase this value.
MT5_BROKER_TZ_OFFSET_HOURS=0


# ── LLM / AI — 7-Provider Hierarchy (8+ keys each) ──────────────
# Round-9 audit fix: expanded from 1 provider (Groq) to 7 providers
# with up to 16 API keys each. The fallback chain is:
#
#   1. Gemini (Primary)         — gemini-2.5-flash
#   2. Cerebras (Secondary)     — gpt-oss-120b
#   3. Groq (Fast Inference)    — llama-3.3-70b-versatile
#   4. SambaNova (Fallback)     — Meta-Llama-3.1-8B-Instruct
#   5. OpenRouter (Router)      — universal router (100+ models)
#   6. GitHub Models (Resort 1) — gpt-4o / Phi-3 / Llama-3.3-70B
#   7. Hugging Face (Resort 2)  — inference endpoints
#
# Each provider supports multi-key rotation via _1..16 suffixes.
# At minimum, set ONE key for your primary provider. The system
# automatically falls through to the next provider on rate-limit/error.
#
# ── 1. Gemini (Primary) ─────────────────────────────────────────
# Get key: https://aistudio.google.com/app/apikey
# Model: gemini-2.5-flash (default) or gemini-2.0-flash
#GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here
#GEMINI_API_KEY_1=your_gemini_key_1
#GEMINI_API_KEY_2=your_gemini_key_2
# ... up to GEMINI_API_KEY_16
#
# ── 2. Cerebras (Secondary) ─────────────────────────────────────
# Get key: https://cloud.cerebras.ai
# Model: gpt-oss-120b (default) or llama3.1-8b-instruct
#CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
#CEREBRAS_MODEL=gpt-oss-120b
#CEREBRAS_API_KEY=your_cerebras_api_key_here
#CEREBRAS_API_KEY_1=your_cerebras_key_1
# ... up to CEREBRAS_API_KEY_16
#
# ── 3. Groq (Fast Inference) ────────────────────────────────────
# Get key: https://console.groq.com
# Model: llama-3.3-70b-versatile (default) or llama-3.1-8b-instant
GROQ_API_KEY=your_groq_api_key_here
#GROQ_API_KEY_1=your_groq_key_1
#GROQ_API_KEY_2=your_groq_key_2
# ... up to GROQ_API_KEY_16
#
# ── 4. SambaNova (Fallback) ─────────────────────────────────────
# Get key: https://cloud.sambanova.ai
# Day 99+ V3 FIX: SambaNova deprecated all Llama 3.1 models (410 Gone).
# Default is now DeepSeek-V3 (current on free tier as of 2026-Q3).
# Override here if you have access to a different current SambaNova model.
#SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
#SAMBANOVA_MODEL=DeepSeek-V3
#SAMBANOVA_API_KEY=your_sambanova_api_key_here
#SAMBANOVA_API_KEY_1=your_sambanova_key_1
# ... up to SAMBANOVA_API_KEY_16
#
# ── 5. OpenRouter (Universal Router) ────────────────────────────
# Get key: https://openrouter.ai/keys
# Model: google/gemma-2-9b-it:free (free) or any paid model
#OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#OPENROUTER_MODEL=google/gemma-2-9b-it:free
#OPENROUTER_MODEL_FALLBACK_1=meta-llama/llama-3.1-8b-instruct:free
#OPENROUTER_MODEL_FALLBACK_2=microsoft/phi-3-mini-128k-instruct:free
#OPENROUTER_API_KEY=your_openrouter_api_key_here
#OPENROUTER_API_KEY_1=your_openrouter_key_1
# ... up to OPENROUTER_API_KEY_16
#
# ── 6. GitHub Models (Last Resort 1) ────────────────────────────
# Get token: https://github.com/settings/tokens (create PAT with
#   `models:read` scope)
# Models: gpt-4o, gpt-4o-mini, Phi-3-medium-128k-instruct,
#         Llama-3.3-70B-Instruct, Mistral-large
#GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com
#GITHUB_MODELS_MODEL=gpt-4o-mini
#GITHUB_TOKEN=your_github_pat_here
#GITHUB_TOKEN_1=your_github_pat_1
# ... up to GITHUB_TOKEN_16
#
# ── 7. Hugging Face (Last Resort 2) ─────────────────────────────
# Get token: https://huggingface.co/settings/tokens
# Models: meta-llama/Meta-Llama-3.1-8B-Instruct,
#         mistralai/Mistral-7B-Instruct-v0.3, etc.
#HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co/v1
#HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
#HF_TOKEN=your_hf_token_here
#HF_TOKEN_1=your_hf_token_1
# ... up to HF_TOKEN_16
#
# ── LLM Throttle Settings ───────────────────────────────────────
# Per-cycle cap (6 pairs × 3 calls each = 18 needed at peak)
MAX_LLM_CALLS_PER_CYCLE=8
# DailyFX's former calendar RSS endpoint is retired; FairEconomy/Trading
# Economics remain in the active fallback chain. Enable only for a known
# compatible mirror.
ENABLE_LEGACY_DAILYFX_RSS=false
# Global rolling-window cap (calls per 60 seconds)
MAX_LLM_CALLS_PER_MIN=18
# Minimum delay between calls to the same provider (seconds)
LLM_CALL_INTERVAL_SEC=2.0

# ── DATA SOURCES ───────────────────────────────────────────────
# Primary data source: mt5, yfinance, alpha_vantage, etc.
PREFERRED_DATA_SOURCE=mt5

# Alpha Vantage (free tier, limited requests)
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# ── TRADING MODE ───────────────────────────────────────────────
# SAFE       — high-confidence-only, all confirmations required
# AUTONOMOUS — system trades per ApprovalMode
TRADING_MODE=SAFE

# Approval mode (for AUTONOMOUS trading mode)
# NOTE: valid values are 1/2/3 — these correspond to the modes
# defined in core/approval_mode.py:
#   1 = ANALYSIS ONLY — AI analyzes, no trades executed
#   2 = SUPERVISED    — AI suggests, human must approve each trade
#                       (this is the safest mode and the recommended default)
#   3 = AUTONOMOUS    — AI trades without human gate
# Earlier versions of this file documented mode "0 = manual approval" which
# is invalid and would crash ApprovalMode.__init__ with KeyError: 0 on boot.
# Use 2 for the equivalent of "manual approval required for every trade".
APPROVAL_MODE=2

# ── TRADING-AS-GIT (approval-gated trading) ───────────────────
# When enabled, trade intentions go through STAGE → COMMIT → PUSH
# with human REJECT at any pre-push step. See docs/trading-as-git.md
# Default: false in paper mode, true in mt5_live mode.
# JOURNAL_ENABLED=false

# Auto-reject staged intentions older than this (seconds)
# JOURNAL_STAGED_TTL_SECONDS=300

# Auto-reject committed intentions older than this (seconds)
# JOURNAL_COMMITTED_TTL_SECONDS=120

# ── OPTIONAL: ECONOMIC CALENDAR ────────────────────────────────
# Forex Factory calendar (for news blackout)
# ECONOMIC_CALENDAR_API_KEY=your_calendar_api_key

# ── OPTIONAL: MONITORING ───────────────────────────────────────
# Sentry for error tracking
# SENTRY_DSN=your_sentry_dsn

# ── OPTIONAL: DASHBOARD AUTHENTICATION ──────────────────────────
# CRITICAL: Set this if dashboard is accessible beyond localhost.
# Without it, anyone can pause/resume trading via the web UI.
# DASHBOARD_PASSWORD=your_secure_password_here

# ── DEVELOPMENT/DEBUG ──────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable verbose LLM logging
# LLM_DEBUG=false
